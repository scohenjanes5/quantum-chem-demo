  RowBox[{"s3", "[", "r_", "]"}], "=", 
  RowBox[{"2", "*", 
   RowBox[{
    RowBox[{"Sqrt", "[", "3", "]"}], "/", "27"}], "*", 
   RowBox[{"(", 
    RowBox[{"3", "-", 
